# Copy to deploy/diet-opt.env and fill in. The launcher (run_server.sh)
# sources this file, and the systemd unit reads it via EnvironmentFile.
# Keep it chmod 600 since it holds the API key.

# Required for the /meal-plan endpoint. Optimization works without it.
ANTHROPIC_API_KEY=sk-ant-...

# Bind address. 127.0.0.1 = local-only; 0.0.0.0 = all interfaces (LAN/WAN).
# Leave at 127.0.0.1 if you put a reverse proxy (Caddy/nginx) in front.
DIET_OPT_HOST=127.0.0.1
DIET_OPT_PORT=8000

# Single worker is fine for personal use; the LP solver is CPU-bound and
# requests are infrequent.
DIET_OPT_WORKERS=1

# If you front this with a reverse proxy on the same host, leave as-is.
# Otherwise list the proxy IPs (comma-separated) so client IPs are honored.
DIET_OPT_TRUSTED_PROXIES=127.0.0.1

# Override the Python interpreter if you don't use ~/Documents/py_venv.
# DIET_OPT_PYTHON=/path/to/venv/bin/python
